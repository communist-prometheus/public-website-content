---
import { getCollection } from 'astro:content';
import BlogPicture from '@/features/blog/components/BlogPicture.astro';
import { getArticleSlug } from '@/features/blog/helpers/getBlogPosts';
import BaseLayout from '@/layouts/BaseLayout.astro';

export const getStaticPaths = async () => {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { lang: post.data.lang, slug: getArticleSlug(post) },
    props: { post },
  }));
};

const { post } = Astro.props;
const { Content } = await post.render();

const { lang } = Astro.params;
---

<BaseLayout title={`${post.data.title} - Prometheus`} description={post.data.description} lang={lang}>
  <article class="section">
    <div class="container">
      <div class="post-header">
        <span class="category">{post.data.category}</span>
        <h1>{post.data.title}</h1>
        <p class="post-meta">
          {
            post.data.pubDate.toLocaleDateString(lang === 'en' ? 'en-US' : 'ru-RU', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })
          }
        </p>
      </div>
      {post.data.image && <div class="featured-image"><BlogPicture image={post.data.image} alt={post.data.title} preset="featured" loading="eager" /></div>}
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    max-width: 800px;
    margin-inline: auto;
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .category {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--color-accent);
    color: var(--color-on-accent);
    font-size: 0.75rem;
    font-weight: 500;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-md);
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--spacing-sm);
  }

  .post-meta {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  .featured-image {
    width: 100%;
    max-width: 1000px;
    margin-inline: auto;
    margin-bottom: var(--spacing-2xl);
  }

  .featured-image :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
  }

  .prose {
    max-width: 800px;
    margin-inline: auto;
  }

  .prose :global(h2) {
    font-size: 1.75rem;
    font-weight: 600;
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
  }

  .prose :global(h3) {
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
  }

  .prose :global(p) {
    margin-bottom: var(--spacing-md);
    line-height: 1.8;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--spacing-md);
    padding-left: var(--spacing-lg);
  }

  .prose :global(li) {
    margin-bottom: var(--spacing-xs);
  }

  .prose :global(code) {
    background: var(--color-surface);
    padding: 0.2em 0.4em;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  .prose :global(pre) {
    background: var(--color-surface);
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-bottom: var(--spacing-md);
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: var(--spacing-md);
    margin-left: 0;
    margin-bottom: var(--spacing-md);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .prose :global(img) {
    width: 100%;
    height: auto;
    margin-block: var(--spacing-lg);
    border-radius: var(--radius-md);
  }

  .prose :global(picture) {
    display: block;
  }

  .prose :global(video) {
    width: 100%;
    margin-block: var(--spacing-lg);
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }

  .prose :global(audio) {
    width: 100%;
    margin-block: var(--spacing-lg);
  }

  .prose :global(figure) {
    margin: var(--spacing-lg) 0;
  }

  .prose :global(figcaption) {
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-top: var(--spacing-xs);
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    transition: color var(--transition-fast);
  }

  .prose :global(a:hover) {
    color: var(--color-accent-hover);
  }
</style>
