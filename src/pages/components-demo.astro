---
import CpButton from '@/components/cp/CpButton.astro';
import CpCard from '@/components/cp/CpCard.astro';
import '@/styles/theme.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Components Demo</title>
  </head>
  <body>
    <h1>Component Library Demo</h1>

    <section>
      <h2>Buttons</h2>

      <h3>Variants</h3>
      <div class="button-group">
        <CpButton variant="primary">Primary Button</CpButton>
        <CpButton variant="secondary">Secondary Button</CpButton>
        <CpButton variant="ghost">Ghost Button</CpButton>
      </div>

      <h3>Sizes</h3>
      <div class="button-group">
        <CpButton size="sm">Small</CpButton>
        <CpButton size="md">Medium</CpButton>
        <CpButton size="lg">Large</CpButton>
      </div>

      <h3>States</h3>
      <div class="button-group">
        <CpButton>Enabled</CpButton>
        <CpButton disabled>Disabled</CpButton>
      </div>
    </section>

    <section>
      <h2>Cards</h2>

      <div class="demo-grid">
        <CpCard>
          <div class="card-content">
            <h3 class="card-title">Basic Card</h3>
            <p class="card-description">This is a simple card component with default styling.</p>
          </div>
        </CpCard>

        <CpCard elevated>
          <div class="card-content">
            <h3 class="card-title">Elevated Card</h3>
            <p class="card-description">This card has a shadow for elevation effect.</p>
          </div>
        </CpCard>

        <CpCard hoverable>
          <div class="card-content">
            <h3 class="card-title">Hoverable Card</h3>
            <p class="card-description">Hover over this card to see the effect.</p>
          </div>
        </CpCard>

        <CpCard hoverable elevated>
          <div class="card-content">
            <h3 class="card-title">Interactive Card</h3>
            <p class="card-description">This card is both hoverable and elevated.</p>
          </div>
        </CpCard>
      </div>
    </section>

    <section>
      <h2>Combined Example</h2>
      <div class="demo-grid">
        <CpCard hoverable elevated>
          <div class="card-content">
            <h3 class="card-title">Sign Up</h3>
            <p class="card-description">Create an account to get started with our platform.</p>
            <div class="card-action">
              <CpButton variant="primary">Get Started</CpButton>
            </div>
          </div>
        </CpCard>

        <CpCard hoverable elevated>
          <div class="card-content">
            <h3 class="card-title">Documentation</h3>
            <p class="card-description">Learn how to use our component library effectively.</p>
            <div class="card-action">
              <CpButton variant="secondary">Read Docs</CpButton>
            </div>
          </div>
        </CpCard>

        <CpCard hoverable elevated>
          <div class="card-content">
            <h3 class="card-title">Contact</h3>
            <p class="card-description">Have questions? Get in touch with our team.</p>
            <div class="card-action">
              <CpButton variant="ghost">Contact Us</CpButton>
            </div>
          </div>
        </CpCard>
      </div>
    </section>
  </body>
</html>

<style>
  body {
    font-family: system-ui, -apple-system, sans-serif;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    background: var(--color-background);
    color: var(--color-text-primary);
  }

  h1 {
    margin-bottom: 2rem;
  }

  section {
    margin-bottom: 3rem;
  }

  h2 {
    margin-bottom: 1rem;
    color: var(--color-text-secondary);
    font-size: 1.25rem;
    font-weight: 500;
  }

  .demo-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  }

  .button-group {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0;
  }

  .card-description {
    color: var(--color-text-secondary);
    margin: 0;
  }

  .card-action {
    margin-top: 1rem;
  }
</style>
