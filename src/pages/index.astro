---
import { getBlogPosts } from '@/features/blog/helpers/getBlogPosts';
import Hero from '@/features/home/components/Hero.astro';
import NewsSection from '@/features/home/components/NewsSection.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const lang = 'en';
const posts = await getBlogPosts(lang);
const latestPosts = posts.slice(0, 3);
---

<BaseLayout title="Prometheus - Modern Web Platform" lang={lang}>
  <Hero
    title="Welcome to Prometheus"
    description="A modern platform for sharing knowledge, ideas, and innovations. Built with cutting-edge web technologies to deliver the best experience."
  />
  <NewsSection posts={latestPosts} lang={lang} />
</BaseLayout>

<script is:inline>
  if (location.pathname === '/') {
    history.replaceState(null, '', '/en');
  }
</script>
