---
import type { CollectionEntry } from 'astro:content';
import CpButton from '@/components/cp/CpButton.astro';
import type { Language } from '@/config/i18n';
import { t } from '@/config/translations';
import PostCard from '@/features/blog/components/PostCard.astro';
import { getArticleSlug } from '@/features/blog/helpers/getBlogPosts';

interface Props {
  posts: CollectionEntry<'blog'>[];
  lang: Language;
}

const { posts, lang } = Astro.props;

const tr = t(lang);
const title = tr.home('latestNews');
const viewAll = tr.home('viewAllPosts');
---

<section class="section">
  <div class="container">
    <div class="section-header">
      <h2>{title}</h2>
      <a href={`/${lang}/blog`}>
        <CpButton variant="secondary">{viewAll}</CpButton>
      </a>
    </div>
    <div class="grid grid-2">
      {
        posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            slug={getArticleSlug(post)}
            image={post.data.image}
            lang={lang}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-xl);
  }

  h2 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 600;
  }

  .section-header {
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }
</style>
