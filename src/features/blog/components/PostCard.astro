---
import type { ImageMetadata } from 'astro';
import CpButton from '@/components/cp/CpButton.astro';
import CpCard from '@/components/cp/CpCard.astro';
import type { Language } from '@/config/i18n';
import { t } from '@/config/translations';
import BlogPicture from '@/features/blog/components/BlogPicture.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  slug: string;
  image?: ImageMetadata | undefined;
  lang: Language;
  headingLevel?: 2 | 3;
}

const { title, description, category, slug, image, lang, headingLevel = 3 } = Astro.props;

const readMore = t(lang).blog('readMore');
---

<CpCard hoverable elevated class="post-card">
  {image && <div class="post-image"><BlogPicture image={image} alt={title} preset="thumbnail" /></div>}
  <div class="post-content">
    <span class="category">{category}</span>
    {headingLevel === 2 ? <h2>{title}</h2> : <h3>{title}</h3>}
    <p class="text-secondary">{description}</p>
    <a href={`/${lang}/blog/${slug}`}>
      <CpButton variant="ghost">{readMore} →</CpButton>
    </a>
  </div>
</CpCard>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    padding: 0;
  }

  .post-image {
    margin: var(--spacing-sm);
    width: calc(100% - var(--spacing-sm) * 2);
    height: 200px;
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .post-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    padding: var(--spacing-lg);
    flex: 1;
  }

  .category {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--color-accent);
    color: var(--color-on-accent);
    font-size: 0.75rem;
    font-weight: 500;
    border-radius: var(--radius-sm);
    width: fit-content;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  h2, h3 {
    font-size: 1.25rem;
    line-height: 1.4;
  }

  p {
    flex: 1;
  }

  a {
    margin-top: var(--spacing-sm);
    width: fit-content;
  }
</style>
