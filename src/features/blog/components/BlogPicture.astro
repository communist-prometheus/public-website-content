---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { IMAGE_PRESETS, type ImagePreset } from '@/features/blog/config/imagePresets';

interface Props {
  image: ImageMetadata;
  alt: string;
  preset: ImagePreset;
  loading?: 'lazy' | 'eager';
}

const { image, alt, preset, loading = 'lazy' } = Astro.props;
const { widths, sizes } = IMAGE_PRESETS[preset];
---

<Picture
  src={image}
  widths={[...widths]}
  sizes={sizes}
  formats={['avif', 'webp']}
  alt={alt}
  loading={loading}
/>
