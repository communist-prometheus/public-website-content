---
---

<cp-button id="theme-toggle" variant="ghost" aria-label="Toggle theme">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
    <circle class="sun" cx="12" cy="12" r="5"></circle>
    <line class="sun" x1="12" y1="1" x2="12" y2="3"></line>
    <line class="sun" x1="12" y1="21" x2="12" y2="23"></line>
    <line class="sun" x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line class="sun" x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line class="sun" x1="1" y1="12" x2="3" y2="12"></line>
    <line class="sun" x1="21" y1="12" x2="23" y2="12"></line>
    <line class="sun" x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line class="sun" x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    <path class="moon" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</cp-button>

<script>
  const html = document.documentElement;

  const setTheme = (theme: string) => {
    html.dataset['theme'] = theme;
    localStorage.setItem('theme', theme);
  };

  const toggleThemeWithAnimation = (event: MouseEvent) => {
    const newTheme = html.dataset['theme'] === 'dark' ? 'light' : 'dark';

    if (!document.startViewTransition) {
      setTheme(newTheme);
      return;
    }

    const x = event.clientX;
    const y = event.clientY;
    const endRadius = Math.hypot(
      Math.max(x, innerWidth - x),
      Math.max(y, innerHeight - y)
    );

    html.style.setProperty('--x', `${x}px`);
    html.style.setProperty('--y', `${y}px`);
    html.style.setProperty('--r', `${endRadius}px`);

    document.startViewTransition(() => {
      setTheme(newTheme);
    });
  };

  customElements.whenDefined('cp-button').then(() => {
    const button = document.getElementById('theme-toggle');
    
    button?.addEventListener('cp-click', ((e: CustomEvent<{ originalEvent: MouseEvent }>) => {
      toggleThemeWithAnimation(e.detail.originalEvent);
    }) as EventListener);
  });
</script>

<style>
  cp-button::part(button) {
    width: 40px;
    height: 40px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  svg {
    width: 20px;
    height: 20px;
    pointer-events: none;
  }

  .sun {
    display: none;
  }

  .moon {
    display: block;
  }

  :global([data-theme='dark']) .sun {
    display: block;
  }

  :global([data-theme='dark']) .moon {
    display: none;
  }
</style>
