---
---

<button id="theme-toggle" class="theme-button" aria-label="Toggle theme">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
    <circle class="sun" cx="12" cy="12" r="5"></circle>
    <line class="sun" x1="12" y1="1" x2="12" y2="3"></line>
    <line class="sun" x1="12" y1="21" x2="12" y2="23"></line>
    <line class="sun" x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line class="sun" x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line class="sun" x1="1" y1="12" x2="3" y2="12"></line>
    <line class="sun" x1="21" y1="12" x2="23" y2="12"></line>
    <line class="sun" x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line class="sun" x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    <path class="moon" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  const html = document.documentElement;

  const setTheme = (theme: string) => {
    html.dataset['theme'] = theme;
    localStorage.setItem('theme', theme);
  };

  const toggleThemeWithAnimation = (event: MouseEvent | Event) => {
    const mouseEvent = event as MouseEvent;
    const newTheme = html.dataset['theme'] === 'dark' ? 'light' : 'dark';

    if (!document.startViewTransition) {
      setTheme(newTheme);
      return;
    }

    const x = mouseEvent.clientX;
    const y = mouseEvent.clientY;
    const endRadius = Math.hypot(
      Math.max(x, innerWidth - x),
      Math.max(y, innerHeight - y)
    );

    html.style.setProperty('--x', `${x}px`);
    html.style.setProperty('--y', `${y}px`);
    html.style.setProperty('--r', `${endRadius}px`);

    const previousNavOldAnimation = html.style.getPropertyValue('--nav-old-animation');
    const previousNavNewAnimation = html.style.getPropertyValue('--nav-new-animation');

    html.style.setProperty('--nav-old-animation', 'none');
    html.style.setProperty('--nav-new-animation', 'none');

    html.classList.add('theme-transition');

    const transition = document.startViewTransition(() => {
      setTheme(newTheme);
    });

    transition.finished.finally(() => {
      html.classList.remove('theme-transition');

      if (previousNavOldAnimation.length > 0) {
        html.style.setProperty('--nav-old-animation', previousNavOldAnimation);
      } else {
        html.style.removeProperty('--nav-old-animation');
      }

      if (previousNavNewAnimation.length > 0) {
        html.style.setProperty('--nav-new-animation', previousNavNewAnimation);
      } else {
        html.style.removeProperty('--nav-new-animation');
      }
    });
  };

  const button = document.getElementById('theme-toggle');
  button?.addEventListener('click', toggleThemeWithAnimation);
</script>

<style>
  .theme-button {
    width: 40px;
    height: 40px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .theme-button:hover {
    background: var(--color-surface);
    transform: translateY(-1px);
  }

  svg {
    width: 20px;
    height: 20px;
    pointer-events: none;
  }

  .sun {
    display: none;
  }

  .moon {
    display: block;
  }

  :global([data-theme='dark']) .sun {
    display: block;
  }

  :global([data-theme='dark']) .moon {
    display: none;
  }
</style>
