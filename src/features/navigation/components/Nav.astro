---
import type { Language } from '@/config/i18n';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const nav = {
  en: [
    { href: `/${lang}`, label: 'Home' },
    { href: `/${lang}/blog`, label: 'Blog' },
    { href: `/${lang}/manifest`, label: 'Manifest' },
  ],
  ru: [
    { href: `/${lang}`, label: 'Главная' },
    { href: `/${lang}/blog`, label: 'Блог' },
    { href: `/${lang}/manifest`, label: 'Манифест' },
  ],
};

const links = nav[lang];
---

<nav>
  <ul>
    {links.map(({ href, label }) => <li><a href={href}>{label}</a></li>)}
  </ul>
</nav>

<script>
  const updateActiveNav = () => {
    const path = globalThis.location.pathname.replace(/\/$/, '') || '/';
    const allNavLinks = document.querySelectorAll<HTMLAnchorElement>('nav a[href]');

    allNavLinks.forEach((link) => {
      const href = link.getAttribute('href')?.replace(/\/$/, '') || '/';
      const isHome = /^\/[a-z]{2}$/.test(href);
      const isActive = isHome ? path === href : path.startsWith(href);

      if (isActive) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  };

  updateActiveNav();
  document.addEventListener('astro:after-swap', updateActiveNav);
</script>

<style>
  ul {
    display: flex;
    gap: var(--spacing-md);
    list-style: none;
    padding: 0;
  }

  a {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  a:hover,
  a:focus-visible {
    color: var(--color-text-primary);
  }

  a[aria-current="page"] {
    color: var(--color-accent);
    font-weight: 600;
  }
</style>
